<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>TopView2026 - Cyber Stone Basin</display-name>

    <!-- 启用注解扫描 -->
    <listener>
        <listener-class>com.xiaozhuo.config.AppStartupListener</listener-class>
    </listener>

    <!-- 欢迎页面 -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>


    <!-- 添加过滤器（注意顺序：限流 → 认证 → 异常处理） -->
    <filter>
        <filter-name>RateLimitFilter</filter-name>
        <filter-class>com.xiaozhuo.filter.RateLimitFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RateLimitFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.xiaozhuo.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>GlobalExceptionFilter</filter-name>
        <filter-class>com.xiaozhuo.filter.GlobalExceptionFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>GlobalExceptionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>



</web-app>
